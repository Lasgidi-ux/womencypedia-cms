{
  "kind": "collectionType",
  "collectionName": "interactive_maps",
  "info": {
    "singularName": "interactive-map",
    "pluralName": "interactive-maps",
    "displayName": "Interactive Map",
    "description": "Geographic visualizations of regions, kingdoms, and migration routes"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "mapType": {
      "type": "enumeration",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "enum": [
        "kingdoms",
        "migration",
        "trade",
        "political",
        "cultural"
      ]
    },
    "coordinates": {
      "type": "json",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "region": {
      "type": "enumeration",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "enum": [
        "Africa",
        "Europe",
        "Asia",
        "Middle East",
        "North America",
        "South America",
        "Oceania",
        "Global"
      ]
    },
    "era": {
      "type": "enumeration",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "enum": [
        "Ancient",
        "Pre-colonial",
        "Colonial",
        "Post-colonial",
        "Contemporary"
      ]
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "mapImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "interactiveData": {
      "type": "json",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    }
  }
}