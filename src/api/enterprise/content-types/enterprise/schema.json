{
  "kind": "collectionType",
  "collectionName": "enterprises",
  "info": {
    "singularName": "enterprise",
    "pluralName": "enterprises",
    "displayName": "Enterprise",
    "description": "Women's economic contributions and business innovations throughout history"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "category": {
      "type": "enumeration",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "enum": [
        "Trade & Commerce",
        "Agriculture & Food",
        "Manufacturing",
        "Healthcare & Medicine",
        "Finance & Banking",
        "Education",
        "Arts & Crafts",
        "Technology"
      ]
    },
    "region": {
      "type": "enumeration",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "enum": [
        "Africa",
        "Europe",
        "Asia",
        "Middle East",
        "North America",
        "South America",
        "Oceania",
        "Global"
      ]
    },
    "era": {
      "type": "enumeration",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "enum": [
        "Ancient",
        "Pre-colonial",
        "Colonial",
        "Post-colonial",
        "Contemporary"
      ]
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "biographies": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::biography.biography",
      "inversedBy": "enterprises"
    },
    "sources": {
      "type": "json",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    }
  }
}